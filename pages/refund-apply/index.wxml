<view class="refund-container">
  <!-- 我的售后记录 -->
  <view class="refund-history" wx:if="{{ refundApplyList && refundApplyList.length > 0 }}">
    <view class="section-title">
      <view class="title-line"></view>
      <text class="title-text">{{ $t.refund.myRefund }}</text>
    </view>
    <view class="history-list">
      <view class="history-item" wx:for="{{ refundApplyList }}" wx:key="id" data-idx="{{ index }}" bind:tap="refundDetail">
        <view class="history-goods">
          <image class="goods-image" src="{{ item.goodInfo.pic }}_m" mode="aspectFill"></image>
          <view class="goods-info">
            <view class="goods-name">{{ item.goodInfo.goodsName }}</view>
            <view class="goods-meta">
              <text class="goods-num">x{{ item.baseInfo.number }}</text>
              <text class="goods-price">¥{{ item.baseInfo.amount }}</text>
            </view>
            <view class="apply-time">{{ $t.refund.applyTime }}：{{ item.baseInfo.dateAdd }}</view>
          </view>
        </view>
        <view class="history-status">
          <text class="status-text">{{ item.baseInfo.statusStr }}</text>
          <view class="arrow-icon">›</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 选择商品 -->
  <view class="section-card">
    <view class="section-title">
      <view class="title-line"></view>
      <text class="title-text">{{ $t.refund.selectGoods }}</text>
    </view>
    <van-radio-group value="{{ goodsIndex }}">
      <view class="goods-list">
        <view class="goods-item {{ !item.afterSale ? 'disabled' : '' }}" wx:for="{{ goods }}" wx:key="id" data-name="{{ index }}" bind:tap="goodsClick">
          <view class="goods-content">
            <view class="goods-name-text">{{ item.goodsName }}</view>
            <view class="not-support" wx:if="{{ !item.afterSale }}">{{ $t.refund.notSupport }}</view>
          </view>
          <van-radio name="{{ index }}" disabled="{{ !item.afterSale }}" checked-color="#CF8E63" />
        </view>
      </view>
    </van-radio-group>
  </view>

  <!-- 商品预览 -->
  <view class="section-card" wx:if="{{ curGoods }}">
    <view class="section-title">
      <view class="title-line"></view>
      <text class="title-text">{{ $t.refund.goodsInfo }}</text>
    </view>
    <view class="goods-preview">
      <image class="preview-image" src="{{ curGoods.pic }}_m" mode="aspectFill"></image>
      <view class="preview-info">
        <view class="preview-name">{{ curGoods.goodsName }}</view>
        <view class="preview-price">¥{{ curGoods.amount }}</view>
      </view>
    </view>
    <view class="quantity-selector">
      <text class="selector-label">{{ $t.refund.refundNumber }}</text>
      <van-stepper value="{{ number }}" integer min="1" max="{{ curGoods.number }}" bind:change="numberChange" button-size="36rpx" input-width="80rpx" />
    </view>
  </view>

  <!-- 售后类型 -->
  <view class="section-card" wx:if="{{ curGoods }}">
    <view class="section-title">
      <view class="title-line"></view>
      <text class="title-text">{{ $t.refund.refundType }}</text>
    </view>
    <van-radio-group value="{{ type }}" bind:change="typeChange">
      <view class="option-list">
        <block wx:for="{{typeItems}}" wx:key="value">
          <view class="option-item" wx:if="{{ curGoods['afterSale' + index] }}" data-name="{{ item.value }}" bind:tap="typeClick">
            <text class="option-text">{{ item.name }}</text>
            <van-radio name="{{ item.value }}" checked-color="#CF8E63" />
          </view>
        </block>
      </view>
    </van-radio-group>
  </view>

  <!-- 货物状态 -->
  <view class="section-card" wx:if="{{ curGoods && type == 0 }}">
    <view class="section-title">
      <view class="title-line"></view>
      <text class="title-text">{{ $t.refund.logisticsStatus }}</text>
    </view>
    <van-radio-group value="{{ logisticsStatus }}" bind:change="logisticsStatusChange">
      <view class="option-list">
        <view class="option-item" wx:for="{{logisticsStatusItems}}" wx:key="value" data-name="{{ item.value }}" bind:tap="logisticsStatusClick">
          <text class="option-text">{{ item.name }}</text>
          <van-radio name="{{ item.value }}" checked-color="#CF8E63" />
        </view>
      </view>
    </van-radio-group>
  </view>

  <!-- 售后原因 -->
  <view class="section-card" wx:if="{{ curGoods }}">
    <view class="section-title">
      <view class="title-line"></view>
      <text class="title-text">{{ $t.refund.refundReason }}</text>
    </view>
    <van-radio-group value="{{ reason }}" bind:change="reasonChange">
      <view class="reason-list">
        <view class="reason-item" wx:for="{{reasons}}" wx:key="*this" data-name="{{ item }}" bind:tap="reasonClick">
          <text class="reason-text">{{ item }}</text>
          <van-radio name="{{ item }}" checked-color="#CF8E63" />
        </view>
      </view>
    </van-radio-group>
  </view>

  <!-- 售后说明 -->
  <view class="section-card" wx:if="{{ curGoods }}">
    <view class="section-title">
      <view class="title-line"></view>
      <text class="title-text">{{ $t.refund.refundRemark }}</text>
      <text class="title-tip">{{ $t.refund.refundRemarkOptional }}</text>
    </view>
    <view class="remark-box">
      <textarea class="remark-input" model:value="{{ remark }}" placeholder="{{ $t.refund.refundRemarkPlaceholder }}" placeholder-class="remark-placeholder" maxlength="500" auto-height></textarea>
    </view>
  </view>

  <!-- 上传图片 -->
  <view class="section-card" wx:if="{{ curGoods }}">
    <view class="section-title">
      <view class="title-line"></view>
      <text class="title-text">{{ $t.refund.uploadProof }}</text>
      <text class="title-tip">{{ $t.refund.uploadProofOptional }}</text>
    </view>
    <view class="upload-box">
      <van-uploader
        accept="image"
        multiple
        max-count="9"
        upload-text="{{ $t.refund.uploadProof }}"
        image-fit="aspectFill"
        file-list="{{ picsList }}"
        bind:after-read="afterPicRead"
        bind:delete="afterPicDel"
      />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-box" wx:if="{{ curGoods }}">
    <button class="submit-btn" bind:tap="bindSave">{{ $t.refund.submitBtn }}</button>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-area"></view>
</view>

<!-- 售后详情弹窗 -->
<van-popup show="{{ popShow }}" position="bottom" round custom-style="max-height: 85vh; background: #FFF9F5;" bind:close="popClose">
  <view class="popup-container">
    <!-- 标题栏 -->
    <view class="popup-header">
      <text class="popup-title">{{ $t.refund.detailTitle }}</text>
      <view class="popup-close" bind:tap="popClose">✕</view>
    </view>

    <!-- 商品信息 -->
    <view class="popup-goods">
      <image class="popup-goods-image" src="{{ curRufund.goodInfo.pic }}_m" mode="aspectFill"></image>
      <view class="popup-goods-info">
        <view class="popup-goods-name">{{ curRufund.goodInfo.goodsName }}</view>
        <view class="popup-goods-meta">
          <text class="popup-goods-num">x{{ curRufund.baseInfo.number }}</text>
          <text class="popup-goods-price">¥{{ curRufund.baseInfo.amount }}</text>
        </view>
      </view>
    </view>

    <!-- 状态提示 -->
    <view class="popup-notice {{ curRufund.baseInfo.status == 4 ? 'success' : curRufund.baseInfo.status == 2 ? 'error' : 'info' }}">
      <view class="notice-icon">
        <text wx:if="{{curRufund.baseInfo.status == 0}}">⏱</text>
        <text wx:if="{{curRufund.baseInfo.status == 2}}">✕</text>
        <text wx:if="{{curRufund.baseInfo.status == 3}}">⚙</text>
        <text wx:if="{{curRufund.baseInfo.status == 4}}">✓</text>
      </view>
      <text class="notice-text">{{ $t.refund.status['s' + curRufund.baseInfo.status] }}</text>
    </view>

    <!-- 寄回地址信息 -->
    <view wx:if="{{ curRufund.baseInfo.status2 > 0 }}" class="back-address-card">
      <view class="address-header">
        <view class="header-icon">📦</view>
        <text class="header-title">{{ $t.refund.backAddress }}</text>
      </view>
      <view class="address-content">
        <view class="address-row">
          <text class="address-label">{{ $t.refund.backAddressName }}：</text>
          <text class="address-text">{{ logisticsContent.linkMan }}</text>
        </view>
        <view class="address-row">
          <text class="address-label">{{ $t.refund.backAddressPhone }}：</text>
          <text class="address-text">{{ logisticsContent.mobile }}</text>
        </view>
        <view class="address-row">
          <text class="address-label">{{ $t.refund.backAddressDetail }}：</text>
          <text class="address-text">{{ logisticsContent.address }}</text>
        </view>
      </view>
      
      <!-- 待填写快递单号 -->
      <view wx:if="{{ curRufund.baseInfo.status2 == 1 }}" class="logistics-action">
        <button class="fill-logistics-btn" bind:tap="showLogisticsDialog">{{ $t.refund.fillLogistics }}</button>
      </view>
      
      <!-- 已填写快递信息 -->
      <view wx:if="{{ curRufund.baseInfo.status2 == 2 }}" class="logistics-filled">
        <view class="filled-header">
          <view class="filled-icon">✓</view>
          <text class="filled-title">{{ $t.refund.logisticsFilled }}</text>
        </view>
        <view class="filled-content">
          <view class="filled-row">
            <text class="filled-label">{{ $t.refund.logisticsCompany }}：</text>
            <text class="filled-value">{{ logisticsContent.shipperName }}</text>
          </view>
          <view class="filled-row">
            <text class="filled-label">{{ $t.refund.logisticsNumber }}：</text>
            <text class="filled-value">{{ logisticsContent.trackingNumber }}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 详细信息 -->
    <view class="popup-details">
      <view class="detail-item">
        <text class="detail-label">{{ $t.refund.applyTime }}</text>
        <text class="detail-value">{{ curRufund.baseInfo.dateAdd }}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">{{ $t.refund.refundType }}</text>
        <text class="detail-value">{{ curRufund.baseInfo.typeStr }}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">{{ $t.refund.logisticsStatus }}</text>
        <text class="detail-value">{{ curRufund.baseInfo.logisticsStatusStr }}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">{{ $t.refund.refundReason }}</text>
        <text class="detail-value">{{ curRufund.baseInfo.reason }}</text>
      </view>
      <view class="detail-item" wx:if="{{ curRufund.baseInfo.remark }}">
        <text class="detail-label">{{ $t.refund.refundRemark }}</text>
        <text class="detail-value remark">{{ curRufund.baseInfo.remark }}</text>
      </view>
    </view>

    <!-- 举证照片 -->
    <view class="popup-photos" wx:if="{{ curRufund.pics && curRufund.pics.length > 0 }}">
      <view class="photos-title">{{ $t.refund.proofImages }}</view>
      <view class="photos-grid">
        <image
          wx:for="{{ curRufund.pics }}" wx:key="*this"
          class="photo-item" mode="aspectFill"
          src="{{ item.pic }}_m"
          data-current="{{ item.pic }}_m"
          bind:tap="previewImageimageList"
        ></image>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="popup-actions">
      <view wx:if="{{ customerServiceType == 'QW' }}" class="action-service" bind:tap="customerService">
        <text class="service-icon">💬</text>
        <text class="service-text">{{ $t.refund.contactService }}</text>
      </view>
      <view wx:else style="margin-bottom: 32rpx;">
        <button class="action-btn" open-type="contact" style="background: #FFF5F0;color: #8B7355;">{{ $t.refund.contactService }}</button>
      </view>
      <view class="action-btn-box">
        <button class="action-btn cancel" wx:if="{{curRufund.baseInfo.status == 0}}" bind:tap="refundApplyCancel">{{ $t.refund.cancelApply }}</button>
        <button class="action-btn disabled" wx:if="{{curRufund.baseInfo.status == 1}}" disabled>{{ $t.refund.status.s1 }}</button>
        <button class="action-btn disabled" wx:if="{{curRufund.baseInfo.status == 2}}" disabled>{{ $t.refund.status.s2 }}</button>
        <button class="action-btn disabled" wx:if="{{curRufund.baseInfo.status == 3}}" disabled>{{ $t.refund.status.s3 }}</button>
        <button class="action-btn disabled success" wx:if="{{curRufund.baseInfo.status == 4}}" disabled>{{ $t.refund.status.s4 }}</button>
      </view>
    </view>
  </view>
</van-popup>

<!-- 快递信息输入弹窗 -->
<van-popup show="{{ logisticsDialogShow }}" position="center" round custom-style="width: 85%; max-width: 600rpx;" bind:close="closeLogisticsDialog">
  <view class="logistics-dialog">
    <view class="dialog-header">
      <text class="dialog-title">{{ $t.refund.fillLogistics }}</text>
      <view class="dialog-close" bind:tap="closeLogisticsDialog">✕</view>
    </view>
    
    <view class="dialog-content">
      <view class="dialog-tip">
        <text class="tip-icon">💡</text>
        <text class="tip-text">{{ $t.refund.logisticsTip }}</text>
      </view>
      
      <view class="input-group">
        <view class="input-label">{{ $t.refund.logisticsCompany }}</view>
        <input 
          class="input-field" 
          placeholder="{{ $t.refund.logisticsCompanyPlaceholder }}" 
          placeholder-class="input-placeholder"
          model:value="{{ shipperName }}"
        />
      </view>
      
      <view class="input-group">
        <view class="input-label">{{ $t.refund.logisticsNumber }}</view>
        <input 
          class="input-field" 
          placeholder="{{ $t.refund.logisticsNumberPlaceholder }}" 
          placeholder-class="input-placeholder"
          model:value="{{ trackingNumber }}"
        />
      </view>
    </view>
    
    <view class="dialog-actions">
      <button class="dialog-btn cancel-btn" bind:tap="closeLogisticsDialog">{{ $t.common.cancel }}</button>
      <button class="dialog-btn confirm-btn" bind:tap="submitLogistics">{{ $t.refund.submitLogistics }}</button>
    </view>
  </view>
</van-popup>
